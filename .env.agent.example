# CTEDemo Agent Worktree Environment Configuration
# Copy to .env in your agent worktree and fill in unique values.
# Fields marked REQUIRED are checked by scripts/validate-agent-env.sh at /init.

# REQUIRED: Backend data mode — used by backend (settings.py), tests
DATA_MODE=memory

# REQUIRED: Frontend data mode — used by frontend (vite config)
VITE_DATA_MODE=memory

# REQUIRED: Backend server port (unique per agent) — used by uvicorn startup
PORT=<unique-port>

# REQUIRED: Frontend API URL — used by frontend (VITE_API_BASE_URL)
VITE_API_BASE_URL=http://localhost:<PORT>

# REQUIRED: CORS allowed origins — used by backend (FastAPI CORS middleware)
CORS_ORIGINS=http://localhost:<frontend-port>

# REQUIRED: Frontend dev server port (unique per agent) — used by vite dev
FRONTEND_PORT=<frontend-port>

# REQUIRED: Agent identity — used by all hooks (resolve_agent_id in hub-query.sh)
EUPRAXIS_AGENT_NAME=<agent-name>

# REQUIRED: Machine identity — used by keepalive, status API
EUPRAXIS_MACHINE_ID=local

# REQUIRED: Hub API URL for story operations — used by hub-query.sh (all API calls)
EUPRAXIS_HUB_URL=http://localhost:8000

# REQUIRED: Hub API auth token — used by hub-query.sh (Authorization header)
EUPRAXIS_HUB_TOKEN=eupraxis-dev-token

# REQUIRED: Project ID for scoped story queries — used by hub-query.sh (project filtering)
EUPRAXIS_PROJECT_ID=<project-uuid>
